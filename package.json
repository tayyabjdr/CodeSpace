{
  "name": "codespace",
  "version": "1.0.0",
  "description": "Vibecoding terminal workspace",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-builder",
    "release": "electron-vite build && electron-builder --publish always",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:icon": "node scripts/build-icon.js",
    "postinstall": "electron-rebuild -f -w node-pty && node scripts/build-icon.js"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.1",
    "@lezer/highlight": "^1.2.3",
    "electron-updater": "^6.3.0",
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^5.5.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0",
    "electron-rebuild": "^3.2.9",
    "electron-vite": "^2.3.0",
    "jsdom": "^24.0.0",
    "png-to-ico": "^2.1.8",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "sharp": "^0.33.5",
    "vitest": "^2.0.0"
  },
  "build": {
    "appId": "com.controlDeck.codespace",
    "productName": "CodeSpace",
    "publish": [
      {
        "provider": "github",
        "owner": "tayyabjdr",
        "repo": "CodeSpace"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "files": [
      "out/**/*",
      "node_modules/node-pty/**/*"
    ],
    "asar": true,
    "asarUnpack": [
      "**/node_modules/node-pty/**/*"
    ],
    "extraResources": []
  }
}
